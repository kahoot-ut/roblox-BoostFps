--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

--// CONFIG
local SETTINGS = {
	RECHECK = 1.5,
	BATCH_SIZE = 120, -- Quantos objetos processar por frame

	DIST = {
		RENDER = 180,
		LIGHT = 100,
		PHYSICS = 120
	},

	FPS = {
		LOW = 35,
		MED = 55
	}
}

type Mode = "LOW" | "MEDIUM" | "HIGH"
local mode: Mode = "HIGH"
local fps = 60

--// CACHE ÚNICO (mais rápido que várias tabelas)
local objects: {Instance} = {}

--// REGISTRO INTELIGENTE
local function isProtected(obj: Instance): boolean
	local char = player.Character
	if char and obj:IsDescendantOf(char) then return true end
	if obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then return true end
	return false
end

local function register(obj: Instance)
	if isProtected(obj) then return end
	table.insert(objects, obj)

	obj.Destroying:Once(function()
		local i = table.find(objects, obj)
		if i then table.remove(objects, i) end
	end)
end

-- Inicialização leve (sem travar)
task.spawn(function()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		register(obj)
		task.wait() -- evita freeze
	end
end)

Workspace.DescendantAdded:Connect(register)

--// FPS TRACKER (mais leve)
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1
		local now = tick()

		if now - last >= 1 then
			fps = frames
			frames = 0
			last = now

			if fps <= SETTINGS.FPS.LOW then
				mode = "LOW"
			elseif fps <= SETTINGS.FPS.MED then
				mode = "MEDIUM"
			else
				mode = "HIGH"
			end
		end
	end)
end)

--// OTIMIZAÇÃO GLOBAL (UMA VEZ)
Lighting.GlobalShadows = false
Lighting.FogEnd = 1e9

pcall(function()
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

--// LOOP PRINCIPAL ULTRA OTIMIZADO
task.spawn(function()
	local index = 1

	while true do
		task.wait(SETTINGS.RECHECK)

		local char = player.Character
		local root = char and char.PrimaryPart
		if not root then continue end

		local pos = root.Position

		local processed = 0

		while processed < SETTINGS.BATCH_SIZE and index <= #objects do
			local obj = objects[index]
			index += 1
			processed += 1

			if not obj or not obj.Parent then continue end

			--// BASEPART (principal custo)
			if obj:IsA("BasePart") then
				local distSq = (obj.Position - pos).Magnitude

				-- LOD EXTREMO
				if distSq > SETTINGS.DIST.RENDER then
					obj.LocalTransparencyModifier = 1
				else
					obj.LocalTransparencyModifier = 0
				end

				obj.CastShadow = false

				if mode ~= "HIGH" then
					obj.Material = Enum.Material.SmoothPlastic
					obj.Reflectance = 0
				end

				-- DESATIVA FÍSICA LONGE
				if mode == "LOW" and distSq > SETTINGS.DIST.PHYSICS then
					obj.CanTouch = false
					obj.AssemblyLinearVelocity = Vector3.zero
				end

			elseif obj:IsA("Light") then
				local p = obj.Parent
				if p and p:IsA("BasePart") then
					local d = (p.Position - pos).Magnitude
					obj.Enabled = (mode ~= "LOW") and (d < SETTINGS.DIST.LIGHT)
				end

			elseif obj:IsA("ParticleEmitter") then
				obj.Enabled = (mode == "HIGH")

			elseif obj:IsA("Decal") or obj:IsA("Texture") then
				obj.Transparency = (mode == "HIGH") and 0 or 1

			elseif obj:IsA("Sound") then
				local p = obj.Parent
				if p and p:IsA("BasePart") then
					obj.Volume = ((p.Position - pos).Magnitude < SETTINGS.DIST.RENDER) and 1 or 0
				end

			elseif obj:IsA("MeshPart") then
				obj.RenderFidelity = Enum.RenderFidelity.Performance
				obj.TextureID = ""

			end
		end

		-- RESET LOOP (circular)
		if index > #objects then
			index = 1
		end
	end
end)

--// LIMPEZA ULTRA LEVE (SEM TRAVAR)
task.spawn(function()
	while true do
		task.wait(10)

		local removed = 0

		for i = #objects, 1, -1 do
			local obj = objects[i]

			if not obj or not obj.Parent then
				table.remove(objects, i)
				removed += 1
			end
		end

		if removed > 0 then
			collectgarbage("step", 50)
		end
	end
end)

--// MODO DESTRUTIVO (GANHO ABSURDO DE FPS)
task.spawn(function()
	task.wait(5)

	for _, v in ipairs(Lighting:GetChildren()) do
		if v:IsA("PostEffect") then
			v.Enabled = false
		end
	end

	local terrain = Workspace:FindFirstChildOfClass("Terrain")
	if terrain then
		terrain.Decoration = false
		terrain.WaterWaveSize = 0
		terrain.WaterWaveSpeed = 0
	end
end)

print("🔥 ULTRA OTIMIZADOR V3 ATIVO")
