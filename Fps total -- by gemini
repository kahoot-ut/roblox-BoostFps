--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

--// CONFIG INTELIGENTE
local SETTINGS = {
	RECHECK = 0.5,
	BASE_BATCH = 120,

	DIST = {
		NEAR = 60,
		MID = 140,
		FAR = 220
	},

	FPS = {
		LOW = 35,
		MED = 55
	},

	SMART_DESTROY = true
}

type Mode = "LOW" | "MEDIUM" | "HIGH"
local mode: Mode = "HIGH"
local fps = 60

--// CACHE
local objects: {Instance} = {}
local indexMap: {[Instance]: number} = {}

local function removeObject(obj: Instance)
	local i = indexMap[obj]
	if not i then return end

	local last = objects[#objects]
	objects[i] = last
	indexMap[last] = i

	objects[#objects] = nil
	indexMap[obj] = nil
end

--// 🔒 PROTEÇÃO FORTE
local function isProtected(obj: Instance): boolean
	local char = player.Character

	if char and obj:IsDescendantOf(char) then return true end
	if obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then return true end

	if obj:IsA("Humanoid")
		or obj:IsA("Tool")
		or obj:IsA("Script")
		or obj:IsA("LocalScript")
		or obj:IsA("ModuleScript")
		or obj:IsA("SpawnLocation")
	then
		return true
	end

	local name = obj.Name:lower()

	if name:find("hitbox")
		or name:find("trigger")
		or name:find("door")
		or name:find("checkpoint")
	then
		return true
	end

	return false
end

--// 🧠 CLASSIFICAÇÃO
local function getType(obj: Instance): string
	if obj:IsA("BasePart") then return "PART" end
	if obj:IsA("Decal") or obj:IsA("Texture") then return "DECAL" end
	if obj:IsA("ParticleEmitter") then return "PARTICLE" end
	if obj:IsA("Light") then return "LIGHT" end
	if obj:IsA("Sound") then return "SOUND" end
	if obj:IsA("MeshPart") then return "MESH" end
	return "OTHER"
end

--// REGISTRO
local function register(obj: Instance)
	if isProtected(obj) then return end

	indexMap[obj] = #objects + 1
	objects[#objects + 1] = obj

	obj.Destroying:Once(function()
		removeObject(obj)
	end)
end

task.spawn(function()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		register(obj)
		task.wait()
	end
end)

Workspace.DescendantAdded:Connect(register)

--// FPS TRACKER
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1
		local now = tick()

		if now - last >= 1 then
			fps = frames
			frames = 0
			last = now

			if fps <= SETTINGS.FPS.LOW then
				mode = "LOW"
			elseif fps <= SETTINGS.FPS.MED then
				mode = "MEDIUM"
			else
				mode = "HIGH"
			end
		end
	end)
end)

--// 🔥 LIGHTING KILL (SAFE)
Lighting.GlobalShadows = false
Lighting.FogEnd = 1e9
Lighting.Brightness = 1

pcall(function()
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

--// LOOP PRINCIPAL
task.spawn(function()
	local index = 1

	while true do
		task.wait(SETTINGS.RECHECK)

		local char = player.Character
		local root = char and char.PrimaryPart
		if not root then continue end

		local pos = root.Position

		local batch = SETTINGS.BASE_BATCH
		if mode == "LOW" then batch = 80 end
		if mode == "MEDIUM" then batch = 100 end

		local processed = 0

		while processed < batch and index <= #objects do
			local obj = objects[index]
			index += 1
			processed += 1

			if not obj or not obj.Parent then continue end
			if isProtected(obj) then continue end

			local t = getType(obj)

			-- BASEPART
			if t == "PART" then
				local part = obj :: BasePart

				local d = part.Position - pos
				local dist = d.Magnitude

				-- 🔥 FAR (ULTRA SIMPLIFICAÇÃO)
				if dist > SETTINGS.DIST.FAR then
					part.LocalTransparencyModifier = 1
					part.CastShadow = false

					if SETTINGS.SMART_DESTROY then
						-- só destrói lixo visual
						if part.Name:lower():find("grass")
							or part.Name:lower():find("detail")
						then
							part:Destroy()
						end
					end

				-- ⚙️ MID
				elseif dist > SETTINGS.DIST.MID then
					part.LocalTransparencyModifier = 0.7
					part.Material = Enum.Material.SmoothPlastic
					part.Reflectance = 0
					part.CastShadow = false

				-- 🎯 NEAR
				else
					part.LocalTransparencyModifier = 0
				end

			elseif t == "DECAL" then
				obj.Transparency = 1

			elseif t == "PARTICLE" then
				obj.Enabled = false

			elseif t == "LIGHT" then
				obj.Enabled = false

			elseif t == "SOUND" then
				obj.Volume = 0

			elseif t == "MESH" then
				local mesh = obj :: MeshPart
				mesh.TextureID = ""
				mesh.RenderFidelity = Enum.RenderFidelity.Performance
			end
		end

		if index > #objects then
			index = 1
		end
	end
end)

--// LIMPEZA
task.spawn(function()
	while true do
		task.wait(10)

		for i = #objects, 1, -1 do
			local obj = objects[i]
			if not obj or not obj.Parent then
				removeObject(obj)
			end
		end

		collectgarbage("step", 150)
	end
end)

print("⚡ ULTRA OTIMIZADOR V5 - INTELIGENTE ATIVO")