--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

--// CONFIGURAÇÕES OTIMIZADAS
local SETTINGS = {
	FPS_CHECK = 1,
	RECHECK = 2, -- Tempo entre varreduras
	
	DISTANCE = {
		LIGHT = 100,
		RENDER = 180,
		PHYSICS = 120,
	},

	FPS = {
		LOW = 35,
		MEDIUM = 55
	}
}

-- Variáveis de controle
type Mode = "LOW" | "MEDIUM" | "HIGH"
local mode: Mode = "HIGH"
local fps = 60

--// CACHES (USANDO TABELAS PARA OBJETOS ESPECÍFICOS)
local database = {
	parts = {} :: {BasePart},
	lights = {} :: {Light},
	particles = {} :: {ParticleEmitter},
	decals = {} :: {Decal},
	textures = {} :: {Texture},
	sounds = {} :: {Sound},
	guis = {} :: {Instance}, -- Billboard ou Surface
	meshes = {} :: {MeshPart},
	constraints = {} :: {Constraint}
}

--// FUNÇÃO DE LIMPEZA (EVITA MEMORY LEAK)
local function unregister(obj: Instance, tbl: {any})
	local index = table.find(tbl, obj)
	if index then
		table.remove(tbl, index)
	end
end

--// PROTEÇÃO (NÃO AFETAR O PLAYER OU INTERFACE)
local function isProtected(obj: Instance): boolean
	local char = player.Character
	if char and obj:IsDescendantOf(char) then return true end
	if obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then return true end
	return false
end

--// REGISTRO DINÂMICO
local function register(obj: Instance)
	if isProtected(obj) then return end

	local targetTable = nil
	
	if obj:IsA("MeshPart") then targetTable = database.meshes
	elseif obj:IsA("BasePart") then targetTable = database.parts
	elseif obj:IsA("Light") then targetTable = database.lights
	elseif obj:IsA("ParticleEmitter") then targetTable = database.particles
	elseif obj:IsA("Decal") then targetTable = database.decals
	elseif obj:IsA("Texture") then targetTable = database.textures
	elseif obj:IsA("Sound") then targetTable = database.sounds
	elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then targetTable = database.guis
	elseif obj:IsA("Constraint") then targetTable = database.constraints
	end

	if targetTable then
		table.insert(targetTable, obj)
		-- Limpa da tabela quando o objeto for destruído
		obj.Destroying:Once(function()
			unregister(obj, targetTable)
		end)
	end
end

-- Inicializar objetos existentes
for _, obj in ipairs(Workspace:GetDescendants()) do
	register(obj)
end
Workspace.DescendantAdded:Connect(register)

--// MONITOR DE FPS (MÉDIA MÓVEL)
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1
		local now = tick()
		
		if now - last >= SETTINGS.FPS_CHECK then
			fps = math.floor((fps + (frames / (now - last))) / 2)
			frames = 0
			last = now

			if fps <= SETTINGS.FPS.LOW then mode = "LOW"
			elseif fps <= SETTINGS.FPS.MEDIUM then mode = "MEDIUM"
			else mode = "HIGH" end
		end
	end)
end)

--// CONFIGURAÇÕES GLOBAIS (UMA VEZ)
Lighting.GlobalShadows = false
Lighting.FogEnd = 1e10
for _, v in ipairs(Lighting:GetChildren()) do
	if v:IsA("PostEffect") then v.Enabled = false end
end

Workspace.StreamingEnabled = true
pcall(function()
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
	Workspace.Terrain.WaterWaveSize = 0
	Workspace.Terrain.WaterWaveSpeed = 0
	Workspace.Terrain.WaterReflectance = 0
end)

--// LOOP PRINCIPAL DE OTIMIZAÇÃO (CUSTO DE CPU REDUZIDO)
task.spawn(function()
	while true do
		task.wait(mode == "LOW" and SETTINGS.RECHECK * 2 or SETTINGS.RECHECK)
		
		local char = player.Character
		local root = char and char.PrimaryPart
		if not root then continue end
		
		local pos = root.Position
		local renderDistSq = SETTINGS.DISTANCE.RENDER ^ 2
		local lightDistSq = SETTINGS.DISTANCE.LIGHT ^ 2

		-- Otimizar Luzes
		for _, l in ipairs(database.lights) do
			local parent = l.Parent
			if parent and parent:IsA("BasePart") then
				local dSq = (parent.Position - pos).SqrMagnitude
				l.Enabled = (mode ~= "LOW") and (dSq < lightDistSq)
				l.Shadows = false
			end
		end

		-- Otimizar Partículas
		for _, p in ipairs(database.particles) do
			if mode == "LOW" then p.Enabled = false
			elseif mode == "MEDIUM" then p.Rate = 5
			else p.Enabled = true end
		end

		-- Otimizar Meshes e Partes (LOD e Física)
		for _, m in ipairs(database.meshes) do
			m.RenderFidelity = (mode == "LOW") and Enum.RenderFidelity.Performance or Enum.RenderFidelity.Automatic
		end

		for _, part in ipairs(database.parts) do
			local dSq = (part.Position - pos).SqrMagnitude
			
			-- Transparência Local (LOD)
			part.LocalTransparencyModifier = (dSq > renderDistSq) and 1 or 0
			part.CastShadow = false
			
			if mode ~= "HIGH" then
				part.Material = Enum.Material.SmoothPlastic
				part.Reflectance = 0
			end
			
			if mode == "LOW" and dSq > (SETTINGS.DISTANCE.PHYSICS ^ 2) then
				part.CanTouch = false
				part.AssemblyLinearVelocity = Vector3.zero
			end
		end

		-- Otimizar Texturas e Decals
		local showDecals = mode == "HIGH"
		for _, d in ipairs(database.decals) do d.Transparency = showDecals and 0 or 1 end
		for _, t in ipairs(database.textures) do t.Transparency = showDecals and 0 or 1 end

		-- Otimizar Interface 3D e Sons
		for _, g in ipairs(database.guis) do
			local p = g.Parent
			if p and p:IsA("BasePart") then
				(g :: any).Enabled = (p.Position - pos).SqrMagnitude < renderDistSq
			end
		end
		
		for _, s in ipairs(database.sounds) do
			local p = s.Parent
			if p and p:IsA("BasePart") then
				s.Volume = (p.Position - pos).SqrMagnitude < renderDistSq and 1 or 0
			end
		end
	end
end)

print("🚀 ULTRA OTIMIZADOR V2 ATIVADO")

--!strict

--// SERVICES
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

--// CONFIGURAÇÕES DE LIMPEZA
local CLEAN_SETTINGS = {
	MAX_RECORDS = 200,      -- Máximo de registros no log interno
	CLEAN_INTERVAL = 10,    -- Limpeza pesada a cada 10 segundos
	TRASH_DIST = 300,       -- Distância para remover itens sem utilidade
}

--// FILTROS DE LIXO
local TRASH_NAMES = {
	"Effect", "Particle", "Bullet", "Shell", "Blood", 
	"Debris", "Fragment", "Part", "Handle"
}

--// FUNÇÕES AUXILIARES
local function isPhysicsDead(part: BasePart): boolean
	-- Verifica se a peça caiu no vácuo ou está parada longe demais
	return part.Position.Y < -100 or (part.AssemblyLinearVelocity.Magnitude < 0.1)
end

local function cleanGarbage()
	local count = 0
	
	-- 1. Limpeza de Peças Soltas no Mundo
	for _, obj in ipairs(Workspace:GetChildren()) do
		if obj:IsA("BasePart") and not obj.Anchored then
			-- Se for uma parte solta sem nome importante, tchau.
			for _, trashName in ipairs(TRASH_NAMES) do
				if string.find(obj.Name, trashName) then
					obj:Destroy()
					count += 1
					break
				end
			end
		end
	end

	-- 2. Limpeza de Sons que já terminaram
	for _, sound in ipairs(Workspace:GetDescendants()) do
		if sound:IsA("Sound") and sound.Playing == false and sound.TimePosition == 0 then
			-- Se o som não está tocando e não está no início, provavelmente é lixo
			sound:Destroy()
			count += 1
		end
	end

	-- 3. Forçar Coleta de Lixo (LUA GC)
	if count > 0 then
		collectgarbage("step", 100)
		print("🧹 JANITOR: Removidos "..count.." objetos inúteis da memória.")
	end
end

--// LOOP DE MANUTENÇÃO
task.spawn(function()
	while true do
		task.wait(CLEAN_SETTINGS.CLEAN_INTERVAL)
		
		-- Executa a limpeza em pedaços para não dar lag (Time Slicing)
		pcall(cleanGarbage)
		
		-- Reduz a taxa de atualização de física de objetos distantes
		-- Isso libera CPU para o jogador
		for _, part in ipairs(Workspace:GetDescendants()) do
			if part:IsA("BasePart") and not part.Anchored then
				local player = game.Players.LocalPlayer
				if player.Character and player.Character.PrimaryPart then
					local dist = (part.Position - player.Character.PrimaryPart.Position).Magnitude
					if dist > 150 then
						part.SetNetworkOwner(nil) -- Devolve pro servidor se estiver longe
					end
				end
			end
		end
	end
end)

--// REMOVEDOR DE TEXTURAS DE TERRENO (MUITO PESADO)
-- Se você não se importa com a estética do chão:
local function simplifyTerrain()
	local terrain = Workspace:FindFirstChildOfClass("Terrain")
