--!strict

--// SERVICES
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

--// CONFIGURAÇÕES ADICIONAIS
local EXTRA_SETTINGS = {
	MAX_VIEW_ANGLE = 75, -- Ângulo de visão para considerar objetos "atrás" do player
	LOW_RAM_MODE = true,  -- Se verdadeiro, remove texturas de alta resolução
	TEXTURE_ID = "rbxassetid://0", -- Textura invisível/nula
}

--// GERENCIADOR DE TEXTURAS (ECONOMIA DE VRAM)
-- Reduz o consumo de memória de vídeo substituindo texturas por cores sólidas
local function minimizeTextures(obj: Instance)
	if obj:IsA("Texture") or obj:IsA("Decal") then
		obj.Texture = EXTRA_SETTINGS.TEXTURE_ID
	elseif obj:IsA("MeshPart") then
		obj.TextureID = ""
	elseif obj:IsA("SpecialMesh") then
		obj.TextureId = ""
	end
end

--// FRUSTUM CULLING SIMPLIFICADO (OTIMIZAÇÃO DE CÂMERA)
-- Esconde objetos que estão totalmente atrás da câmera do jogador
local function isFacing(part: BasePart): boolean
	local camera = Workspace.CurrentCamera
	if not camera then return true end
	
	local direction = (part.Position - camera.CFrame.Position).Unit
	local look = camera.CFrame.LookVector
	local dot = direction:Dot(look)
	
	-- Se o dot product for menor que 0, o objeto está atrás da câmera
	return dot > 0.2 
end

--// APLICAÇÃO DE REGRAS DE RENDERIZAÇÃO DA ENGINE
local function applyEngineOptimizations()
	-- Força o nível de detalhe das meshes para o mínimo possível
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
	
	-- Ajusta propriedades de iluminação que pesam na GPU
	Lighting.GlobalShadows = false
	Lighting.Outlines = false
	Lighting.Technology = Enum.Technology.Compatibility -- Tenta forçar o modo mais leve
	
	-- Desativa efeitos ambientais pesados
	for _, effect in ipairs(Lighting:GetChildren()) do
		if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("SunRaysEffect") then
			(effect as any).Enabled = false
		end
	end
end

--// LOOP DE VISIBILIDADE (ECONOMIA DE DRAW CALLS)
task.spawn(function()
	applyEngineOptimizations()
	
	while true do
		task.wait(0.5) -- Frequência moderada para não pesar a CPU
		
		local camera = Workspace.CurrentCamera
		if not camera then continue end

		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("BasePart") and not obj.Anchored then
				-- Se o objeto está muito longe ou atrás da câmera, para de renderizar
				if not isFacing(obj) then
					obj.LocalTransparencyModifier = 1
				else
					-- O script anterior cuidará da transparência por distância
				end
			end
			
			-- Se o modo Low RAM estiver ativo, limpa texturas novas que aparecerem
			if EXTRA_SETTINGS.LOW_RAM_MODE then
				if obj:IsA("Texture") or obj:IsA("Decal") or obj:IsA("MeshPart") then
					minimizeTextures(obj)
				end
			end
		end
	end
end)

--// REMOÇÃO DE DECORAÇÕES INÚTEIS
local function nukeExtraDecor()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Clouds") or obj:IsA("Sky") then
			-- Opcional: manter o Sky se não quiser um céu preto, mas Clouds pesam.
			if obj:IsA("Clouds") then obj:Destroy() end
		end
	end
end

nukeExtraDecor()

