--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

--// CONFIG
local SETTINGS = {
	FPS_CHECK = 1,
	RECHECK = 2,

	DISTANCE = {
		LIGHT = 120,
		RENDER = 200,
		PHYSICS = 150
	},

	FPS = {
		LOW = 30,
		MEDIUM = 50
	}
}

type Mode = "LOW" | "MEDIUM" | "HIGH"
local mode: Mode = "HIGH"

--// CACHE
local lights = {}
local particles = {}
local parts = {}

--// FPS TRACK (SUAVE)
local fps = 60
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1

		if tick() - last >= SETTINGS.FPS_CHECK then
			local newFPS = frames
			fps = math.floor((fps + newFPS) / 2)

			frames = 0
			last = tick()

			if fps <= SETTINGS.FPS.LOW then
				mode = "LOW"
			elseif fps <= SETTINGS.FPS.MEDIUM then
				mode = "MEDIUM"
			else
				mode = "HIGH"
			end
		end
	end)
end)

--// PROTEÇÃO
local function protected(obj: Instance): boolean
	local char = player.Character
	if char and obj:IsDescendantOf(char) then return true end
	if obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then return true end
	return false
end

--// REGISTRO
local function register(obj: Instance)
	if protected(obj) then return end

	if obj:IsA("BasePart") then
		table.insert(parts, obj)

	elseif obj:IsA("Light") then
		table.insert(lights, obj)

	elseif obj:IsA("ParticleEmitter") then
		table.insert(particles, obj)
	end
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	register(obj)
end

Workspace.DescendantAdded:Connect(register)

--// GLOBAL CLEAN
Lighting.GlobalShadows = false
Lighting.FogEnd = 1e10

for _, v in ipairs(Lighting:GetChildren()) do
	if v:IsA("PostEffect") then
		v.Enabled = false
	end
end

--// LOOP PRINCIPAL INTELIGENTE
task.spawn(function()
	while true do
		task.wait(SETTINGS.RECHECK)

		local char = player.Character
		if not char or not char.PrimaryPart then continue end

		local pos = char.PrimaryPart.Position

		-- 💡 LUZES
		for _, l in ipairs(lights) do
			if l.Parent and l.Parent:IsA("BasePart") then
				local d = (l.Parent.Position - pos).Magnitude

				if mode == "LOW" then
					l.Enabled = false

				elseif mode == "MEDIUM" then
					l.Enabled = d < SETTINGS.DISTANCE.LIGHT
					l.Shadows = false

				else
					l.Enabled = true
				end
			end
		end

		-- ✨ PARTÍCULAS
		for _, p in ipairs(particles) do
			if mode == "LOW" then
				p.Enabled = false

			elseif mode == "MEDIUM" then
				p.Rate = math.min(p.Rate, 8)

			else
				p.Enabled = true
			end
		end

		-- 📦 LOD + FÍSICA
		for _, part in ipairs(parts) do
			if part and part.Parent then
				local d = (part.Position - pos).Magnitude

				-- 🔥 LOD (DESAPARECE LONGE)
				if d > SETTINGS.DISTANCE.RENDER then
					part.LocalTransparencyModifier = 1

				else
					part.LocalTransparencyModifier = 0
				end

				-- ⚙️ FÍSICA
				if mode == "LOW" and d > SETTINGS.DISTANCE.PHYSICS then
					part.CanCollide = true
					part.CanTouch = false
				end

				-- 🌑 SOMBRA
				part.CastShadow = false
			end
		end
	end
end)

print("🚀 ULTRA PRO++ ATIVADO")

--// EXTRA CACHE
local decals = {}
local textures = {}
local sounds = {}
local guis = {}
local meshes = {}
local constraints = {}

--// REGISTRO EXTRA
local function registerExtra(obj: Instance)
	if protected(obj) then return end

	if obj:IsA("Decal") then
		table.insert(decals, obj)

	elseif obj:IsA("Texture") then
		table.insert(textures, obj)

	elseif obj:IsA("Sound") then
		table.insert(sounds, obj)

	elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then
		table.insert(guis, obj)

	elseif obj:IsA("MeshPart") then
		table.insert(meshes, obj)

	elseif obj:IsA("Constraint") then
		table.insert(constraints, obj)
	end
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	registerExtra(obj)
end

Workspace.DescendantAdded:Connect(registerExtra)

--// OTIMIZAÇÕES GLOBAIS PESADAS
Workspace.StreamingEnabled = true
Workspace.StreamingMinRadius = 64
Workspace.StreamingTargetRadius = 128

pcall(function()
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

-- TERRAIN
pcall(function()
	Workspace.Terrain.WaterWaveSize = 0
	Workspace.Terrain.WaterWaveSpeed = 0
	Workspace.Terrain.WaterReflectance = 0
	Workspace.Terrain.WaterTransparency = 1
end)

--// LOOP EXTRA ULTRA
task.spawn(function()
	while true do
		task.wait(SETTINGS.RECHECK)

		local char = player.Character
		if not char or not char.PrimaryPart then continue end

		local pos = char.PrimaryPart.Position

		-- 🖼️ DECALS / TEXTURES
		for _, d in ipairs(decals) do
			if d.Parent and d.Parent:IsA("BasePart") then
				local dist = (d.Parent.Position - pos).Magnitude

				if mode == "LOW" or dist > SETTINGS.DISTANCE.RENDER then
					d.Transparency = 1
				else
					d.Transparency = 0
				end
			end
		end

		for _, t in ipairs(textures) do
			if t.Parent and t.Parent:IsA("BasePart") then
				local dist = (t.Parent.Position - pos).Magnitude

				if mode ~= "HIGH" then
					t.Transparency = 1
				else
					t.Transparency = 0
				end
			end
		end

		-- 🔊 SONS
		for _, s in ipairs(sounds) do
			if s.Parent and s.Parent:IsA("BasePart") then
				local dist = (s.Parent.Position - pos).Magnitude

				if dist > SETTINGS.DISTANCE.RENDER then
					s.Volume = 0
				else
					s.Volume = 1
				end
			end
		end

		-- 🧾 GUIS 3D
		for _, g in ipairs(guis) do
			if g.Parent and g.Parent:IsA("BasePart") then
				local dist = (g.Parent.Position - pos).Magnitude

				g.Enabled = dist < SETTINGS.DISTANCE.RENDER
			end
		end

		-- 🔺 MESH OTIMIZAÇÃO
		for _, m in ipairs(meshes) do
			if mode == "LOW" then
				m.RenderFidelity = Enum.RenderFidelity.Performance
			elseif mode == "MEDIUM" then
				m.RenderFidelity = Enum.RenderFidelity.Automatic
			end
		end

		-- ⚙️ CONSTRAINTS
		for _, c in ipairs(constraints) do
			if mode == "LOW" then
				c.Enabled = false
			else
				c.Enabled = true
			end
		end

		-- 📦 PARTES EXTRA OTIMIZAÇÃO
		for _, part in ipairs(parts) do
			if part and part.Parent then
				-- MATERIAL SIMPLES
				if mode ~= "HIGH" then
					part.Material = Enum.Material.SmoothPlastic
					part.Reflectance = 0
				end

				-- REMOVE VELOCIDADE (FÍSICA)
				if mode == "LOW" then
					part.AssemblyLinearVelocity = Vector3.zero
					part.AssemblyAngularVelocity = Vector3.zero
				end
			end
		end
	end
end)
