--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

--// CONFIG
local SETTINGS = {
	BATCH = 500,

	DIST_NEAR = 80,
	DIST_MID = 180,

	FOV_DOT = 0.35, -- quanto menor = mais agressivo (0.35 = ~120° visão)

	FPS_LOW = 35,
	FPS_MED = 55
}

local NEAR_SQ = SETTINGS.DIST_NEAR^2
local MID_SQ = SETTINGS.DIST_MID^2

--// STATE
local objects: {BasePart} = {}
local indexMap: {[Instance]: number} = {}
local originalParent: {[Instance]: Instance} = {}
local cursor = 1

local fps = 60
local mode = "HIGH"

--// REGISTER
local function register(obj: Instance)
	if not obj:IsA("BasePart") then return end
	if obj:IsDescendantOf(player.Character or nil) then return end

	indexMap[obj] = #objects + 1
	objects[#objects + 1] = obj

	obj.Destroying:Once(function()
		indexMap[obj] = nil
	end)
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	register(obj)
end

Workspace.DescendantAdded:Connect(register)

--// FPS TRACK
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1
		if tick() - last >= 1 then
			fps = frames
			frames = 0
			last = tick()

			if fps <= SETTINGS.FPS_LOW then
				mode = "LOW"
			elseif fps <= SETTINGS.FPS_MED then
				mode = "MEDIUM"
			else
				mode = "HIGH"
			end
		end
	end)
end)

--// NEXT BATCH
local function nextBatch(size)
	local batch = {}

	for i = 1, size do
		if cursor > #objects then
			cursor = 1
			break
		end

		batch[#batch+1] = objects[cursor]
		cursor += 1
	end

	return batch
end

--// MAIN LOOP
task.spawn(function()
	while true do
		local waitTime = 0.1
		local budget = SETTINGS.BATCH

		if mode == "LOW" then
			waitTime = 0.2
			budget = 300
		elseif mode == "MEDIUM" then
			waitTime = 0.14
			budget = 400
		end

		task.wait(waitTime)

		local char = player.Character
		local root = char and char.PrimaryPart
		if not root then continue end

		local camPos = camera.CFrame.Position
		local camLook = camera.CFrame.LookVector

		for _, part in ipairs(nextBatch(budget)) do
			if not part or not part.Parent then continue end

			local diff = part.Position - camPos

			-- distância sem sqrt
			local distSq = diff.X*diff.X + diff.Y*diff.Y + diff.Z*diff.Z

			-- direção normalizada simplificada
			local mag = math.max(distSq, 0.0001)
			local dir = diff / mag

			-- dot product (visão)
			local dot = dir:Dot(camLook)

			-- 🔥 FORA DA TELA = HIBERNAR
			if dot < SETTINGS.FOV_DOT then
				if not originalParent[part] then
					originalParent[part] = part.Parent
					part.Parent = nil
				end
				continue
			end

			-- NEAR
			if distSq <= NEAR_SQ then
				if originalParent[part] then
					part.Parent = originalParent[part]
					originalParent[part] = nil
				end

				part.LocalTransparencyModifier = 0
				part.CanCollide = true

			-- MID
			elseif distSq <= MID_SQ then
				if originalParent[part] then
					part.Parent = originalParent[part]
					originalParent[part] = nil
				end

				part.LocalTransparencyModifier = 0.5
				part.CastShadow = false
				part.Material = Enum.Material.SmoothPlastic

			-- FAR
			else
				if not originalParent[part] then
					originalParent[part] = part.Parent
					part.Parent = nil
				end
			end
		end
	end
end)

-- CLEAN
task.spawn(function()
	while true do
		task.wait(10)

		for i = #objects, 1, -1 do
			local obj = objects[i]
			if not obj or not obj.Parent then
				objects[i] = nil
			end
		end

		collectgarbage("step", 400)
	end
end)

print("💀 OTIMIZADOR V8 EXTREMO ATIVO")