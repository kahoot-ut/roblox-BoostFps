--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

--// CONFIG
local SETTINGS = {
	GRID_SIZE = 200,
	UPDATE_RATE = 0.1,
	MAX_PER_FRAME = 120,

	DIST_NEAR = 100,
	DIST_MID = 250,
	DIST_FAR = 500,
}

--// TYPES
type ModelData = {
	model: Model,
	parts: {BasePart},
	primary: BasePart,
	priority: number,
	lastState: number
}

--// STATE
local models: {ModelData} = {}
local trackedModels: {[Model]: boolean} = {}
local grid: {[string]: {ModelData}} = {}

--// PRIORITY
local function getPriority(part: BasePart): number
	local size = part.Size.Magnitude
	if size > 20 then return 3 end
	if size > 8 then return 2 end
	return 1
end

--// GRID
local function gridKey(pos: Vector3): string
	return math.floor(pos.X / SETTINGS.GRID_SIZE) .. "," .. math.floor(pos.Z / SETTINGS.GRID_SIZE)
end

local function addToGrid(data: ModelData)
	local key = gridKey(data.primary.Position)
	grid[key] = grid[key] or {}
	table.insert(grid[key], data)
end

--// GET MODEL
local function getModel(inst: Instance): Model?
	if inst:IsA("Model") then return inst end
	return inst:FindFirstAncestorOfClass("Model")
end

--// REGISTER
local function register(obj: Instance)
	if not obj:IsA("BasePart") then return end

	local char = player.Character
	if char and obj:IsDescendantOf(char) then return end

	local model = getModel(obj)
	if not model or trackedModels[model] then return end

	local parts = {}
	for _, d in ipairs(model:GetDescendants()) do
		if d:IsA("BasePart") then
			table.insert(parts, d)
		end
	end

	local primary = model.PrimaryPart or parts[1]
	if not primary then return end

	local data: ModelData = {
		model = model,
		parts = parts,
		primary = primary,
		priority = getPriority(primary),
		lastState = -1
	}

	trackedModels[model] = true
	table.insert(models, data)
	addToGrid(data)
end

--// INITIAL LOAD
for _, obj in ipairs(Workspace:GetDescendants()) do
	register(obj)
end

Workspace.DescendantAdded:Connect(register)

--// APPLY STATE
local function applyModelState(data: ModelData, state: number)
	if data.lastState == state then return end
	data.lastState = state

	for _, part in ipairs(data.parts) do
		if not part or not part.Parent then continue end

		if state == 0 then
			part.LocalTransparencyModifier = 0
			part.CanCollide = true

		elseif state == 1 then
			part.LocalTransparencyModifier = 0.4
			part.CanCollide = true

		elseif state == 2 then
			part.LocalTransparencyModifier = 0.85
			part.CanCollide = false

		else
			part.LocalTransparencyModifier = 1
			part.CanCollide = false
		end
	end
end

--// MAIN LOOP
task.spawn(function()
	while true do
		task.wait(SETTINGS.UPDATE_RATE)

		local camPos = camera.CFrame.Position
		local baseX = math.floor(camPos.X / SETTINGS.GRID_SIZE)
		local baseZ = math.floor(camPos.Z / SETTINGS.GRID_SIZE)

		local checked = 0

		for dx = -1, 1 do
			for dz = -1, 1 do
				local key = (baseX + dx) .. "," .. (baseZ + dz)
				local cell = grid[key]
				if not cell then continue end

				for _, data in ipairs(cell) do
					if checked >= SETTINGS.MAX_PER_FRAME then break end
					checked += 1

					local part = data.primary
					if not part or not part.Parent then continue end

					local dist = (part.Position - camPos).Magnitude

					local near = SETTINGS.DIST_NEAR * (1 + data.priority * 0.2)
					local mid  = SETTINGS.DIST_MID  * (1 + data.priority * 0.15)
					local far  = SETTINGS.DIST_FAR  * (1 + data.priority * 0.1)

					if dist <= near then
						applyModelState(data, 0)
					elseif dist <= mid then
						applyModelState(data, 1)
					elseif dist <= far then
						applyModelState(data, 2)
					else
						applyModelState(data, 3)
					end
				end
			end
		end
	end
end)

--// CLEANUP LOOP
task.spawn(function()
	while true do
		task.wait(10)

		for i = #models, 1, -1 do
			local data = models[i]
			if not data.model or not data.model.Parent then
				trackedModels[data.model] = nil
				table.remove(models, i)
			end
		end

		collectgarbage("step", 300)
	end
end)

print("🚀 V12 OPTIMIZER (MODEL + GRID) ACTIVE")