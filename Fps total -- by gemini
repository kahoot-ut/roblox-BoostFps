--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

--// CONFIG
local SETTINGS = {
	BATCH_MIN = 200,
	BATCH_MAX = 700,

	DIST_NEAR = 80,
	DIST_MID = 180,
	DIST_FAR = 400,

	FOV_DOT = 0.06,

	FPS_LOW = 35,
	FPS_MED = 55,
}

local NEAR_SQ = SETTINGS.DIST_NEAR^2
local MID_SQ = SETTINGS.DIST_MID^2
local FAR_SQ = SETTINGS.DIST_FAR^2

--// STATE
type ObjData = {
	part: BasePart,
	priority: number,
	lastState: number
}

local objects: {ObjData} = {}
local cursor = 1
local fps = 60

--// PRIORITY SYSTEM
local function getPriority(part: BasePart): number
	local size = part.Size.Magnitude

	if size > 20 then return 3 end -- grande (importante)
	if size > 8 then return 2 end  -- médio
	return 1 -- pequeno
end

--// FILTER
local function shouldTrack(obj: Instance)
	if not obj:IsA("BasePart") then return false end
	if obj:IsDescendantOf(player.Character or nil) then return false end
	if obj.Name == "HumanoidRootPart" then return false end

	-- ignora partes minúsculas (grande ganho!)
	if obj.Size.Magnitude < 1 then return false end

	return true
end

--// REGISTER
local function register(obj: Instance)
	if not shouldTrack(obj) then return end

	local part = obj :: BasePart

	table.insert(objects, {
		part = part,
		priority = getPriority(part),
		lastState = -1
	})
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	register(obj)
end

Workspace.DescendantAdded:Connect(register)

--// FPS TRACK
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1
		if tick() - last >= 1 then
			fps = frames
			frames = 0
			last = tick()
		end
	end)
end)

--// NEXT BATCH (PRIORITY AWARE)
local function nextBatch(size)
	local batch = {}

	for i = 1, size do
		if cursor > #objects then
			cursor = 1
			break
		end

		local obj = objects[cursor]
		cursor += 1

		if obj and obj.part and obj.part.Parent then
			table.insert(batch, obj)
		end
	end

	return batch
end

--// APPLY STATE (COM CACHE)
local function applyState(data: ObjData, state: number)
	if data.lastState == state then return end
	data.lastState = state

	local part = data.part

	if state == 0 then -- NEAR
		part.LocalTransparencyModifier = 0
		part.CastShadow = true
		part.CanCollide = true

	elseif state == 1 then -- MID
		part.LocalTransparencyModifier = 0.4
		part.CastShadow = false
		part.Material = Enum.Material.SmoothPlastic
		part.CanCollide = true

	elseif state == 2 then -- FAR
		part.LocalTransparencyModifier = 0.85
		part.CastShadow = false
		part.CanCollide = false

	elseif state == 3 then -- HIDDEN
		part.LocalTransparencyModifier = 1
		part.CastShadow = false
		part.CanCollide = false
	end
end

--// MAIN LOOP
task.spawn(function()
	while true do
		local budget = math.clamp(math.floor(fps * 7), SETTINGS.BATCH_MIN, SETTINGS.BATCH_MAX)
		task.wait(math.clamp(1 / fps, 0.08, 0.2))

		local camCF = camera.CFrame
		local camPos = camCF.Position
		local camLook = camCF.LookVector

		for _, data in ipairs(nextBatch(budget)) do
			local part = data.part

			local diff = part.Position - camPos
			local distSq = diff.X*diff.X + diff.Y*diff.Y + diff.Z*diff.Z

			local mag = math.sqrt(distSq)
			if mag == 0 then continue end

			local dir = diff / mag
			local dot = dir:Dot(camLook)

			-- prioridade afeta agressividade
			local priorityBoost = data.priority * 0.05

			if dot < (SETTINGS.FOV_DOT - priorityBoost) then
				applyState(data, 3)
				continue
			end

			if distSq <= NEAR_SQ then
				applyState(data, 0)

			elseif distSq <= MID_SQ then
				applyState(data, 1)

			elseif distSq <= FAR_SQ then
				applyState(data, 2)

			else
				applyState(data, 3)
			end
		end
	end
end)

--// CLEAN
task.spawn(function()
	while true do
		task.wait(10)

		for i = #objects, 1, -1 do
			local obj = objects[i]
			if not obj or not obj.part or not obj.part.Parent then
				table.remove(objects, i)
			end
		end

		collectgarbage("step", 300)
	end
end)

print("🚀 OTIMIZADOR V10 INTELIGENTE ATIVO")