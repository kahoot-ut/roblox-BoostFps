--!strict

--// SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

--// CONFIG
local SETTINGS = {
	RECHECK = 0.12,
	BASE_BATCH = 250,

	DIST = {
		NEAR = 70,
		MID = 150,
		FAR = 260
	},

	FPS = {
		LOW = 35,
		MED = 55
	}
}

type Mode = "LOW" | "MEDIUM" | "HIGH"
local mode: Mode = "HIGH"
local fps = 60

--// CACHE
local objects: {Instance} = {}
local indexMap: {[Instance]: number} = {}

local originalProps: {[Instance]: any} = {}

--// REMOVE
local function removeObject(obj: Instance)
	local i = indexMap[obj]
	if not i then return end

	local last = objects[#objects]
	objects[i] = last
	indexMap[last] = i

	objects[#objects] = nil
	indexMap[obj] = nil
	originalProps[obj] = nil
end

--// PROTECTION
local function isProtected(obj: Instance): boolean
	local char = player.Character

	if char and obj:IsDescendantOf(char) then return true end
	if obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then return true end

	if obj:IsA("Humanoid")
		or obj:IsA("Tool")
		or obj:IsA("Script")
		or obj:IsA("LocalScript")
		or obj:IsA("ModuleScript")
	then
		return true
	end

	return false
end

--// TYPE
local function getType(obj: Instance): string
	if obj:IsA("BasePart") then return "PART" end
	if obj:IsA("Decal") or obj:IsA("Texture") then return "DECAL" end
	if obj:IsA("ParticleEmitter") then return "PARTICLE" end
	if obj:IsA("Light") then return "LIGHT" end
	if obj:IsA("Sound") then return "SOUND" end
	if obj:IsA("MeshPart") then return "MESH" end
	return "OTHER"
end

--// REGISTER
local function register(obj: Instance)
	if isProtected(obj) then return end

	indexMap[obj] = #objects + 1
	objects[#objects + 1] = obj

	-- salvar estado original
	if obj:IsA("BasePart") then
		originalProps[obj] = {
			Material = obj.Material,
			Reflectance = obj.Reflectance,
			CastShadow = obj.CastShadow,
			Transparency = obj.Transparency
		}
	elseif obj:IsA("MeshPart") then
		originalProps[obj] = {
			TextureID = obj.TextureID
		}
	end

	obj.Destroying:Once(function()
		removeObject(obj)
	end)
end

-- inicial
task.spawn(function()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		register(obj)
	end
end)

Workspace.DescendantAdded:Connect(register)

--// FPS TRACKER
task.spawn(function()
	local last = tick()
	local frames = 0

	RunService.Heartbeat:Connect(function()
		frames += 1
		local now = tick()

		if now - last >= 1 then
			fps = frames
			frames = 0
			last = now

			if fps <= SETTINGS.FPS.LOW then
				mode = "LOW"
			elseif fps <= SETTINGS.FPS.MED then
				mode = "MEDIUM"
			else
				mode = "HIGH"
			end
		end
	end)
end)

--// LIGHTING BOOST
Lighting.GlobalShadows = false
Lighting.FogEnd = 1e9
Lighting.Brightness = 1

pcall(function()
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

--// PRIORITY BUFFERS (sem sort pesado)
local nearList, midList, farList = {}, {}, {}

--// LOOP
task.spawn(function()
	while true do
		task.wait(SETTINGS.RECHECK)

		local char = player.Character
		local root = char and char.PrimaryPart
		if not root then continue end

		local pos = root.Position

		-- limpa listas
		table.clear(nearList)
		table.clear(midList)
		table.clear(farList)

		-- classifica rapidamente
		for _, obj in ipairs(objects) do
			if obj:IsA("BasePart") then
				local dist = (obj.Position - pos).Magnitude

				if dist <= SETTINGS.DIST.NEAR then
					nearList[#nearList+1] = obj
				elseif dist <= SETTINGS.DIST.MID then
					midList[#midList+1] = obj
				else
					farList[#farList+1] = obj
				end
			end
		end

		local function process(list, level)
			local count = 0
			local max = SETTINGS.BASE_BATCH

			if mode == "LOW" then max = 180 end
			if mode == "MEDIUM" then max = 220 end

			for i = 1, #list do
				if count >= max then break end
				count += 1

				local obj = list[i]
				if not obj or not obj.Parent then continue end

				local t = getType(obj)

				if t == "PART" then
					local part = obj :: BasePart
					local original = originalProps[part]

					if level == "NEAR" then
						if original then
							part.Material = original.Material
							part.Reflectance = original.Reflectance
							part.CastShadow = original.CastShadow
							part.Transparency = original.Transparency
						end
						part.LocalTransparencyModifier = 0

					elseif level == "MID" then
						part.LocalTransparencyModifier = 0.5
						part.Material = Enum.Material.SmoothPlastic
						part.CastShadow = false

					elseif level == "FAR" then
						part.LocalTransparencyModifier = 1
						part.CastShadow = false
					end

				elseif t == "DECAL" then
					obj.Transparency = (level == "NEAR") and 0 or 1

				elseif t == "PARTICLE" then
					obj.Enabled = (level == "NEAR")

				elseif t == "LIGHT" then
					obj.Enabled = (level == "NEAR")

				elseif t == "SOUND" then
					obj.Volume = (level == "NEAR") and 1 or 0

				elseif t == "MESH" then
					local mesh = obj :: MeshPart
					local original = originalProps[mesh]

					if level == "NEAR" then
						if original then
							mesh.TextureID = original.TextureID
						end
					else
						mesh.TextureID = ""
						mesh.RenderFidelity = Enum.RenderFidelity.Performance
					end
				end
			end
		end

		-- 🔥 PRIORIDADE REAL
		process(nearList, "NEAR")
		process(midList, "MID")
		process(farList, "FAR")
	end
end)

--// CLEAN
task.spawn(function()
	while true do
		task.wait(8)

		for i = #objects, 1, -1 do
			local obj = objects[i]
			if not obj or not obj.Parent then
				removeObject(obj)
			end
		end

		collectgarbage("step", 200)
	end
end)

print("⚡ ULTRA OTIMIZADOR V6 ATIVO")