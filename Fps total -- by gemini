--!strict

--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local GuiService = game:GetService("GuiService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

--// CONFIGURAÇÕES
local UI_SETTINGS = {
	DISABLE_LOADER = true,     -- Desativa animações de carregamento se o FPS estiver baixo
	UI_RECHECK_RATE = 5,       -- Segundos entre varreduras de UI
	MAX_NETWORK_DISTANCE = 200 -- Distância para ignorar atualizações de física de outros
}

--// GERENCIADOR DE CONEXÕES (PREVINE LEAKS)
local connections: {RBXScriptConnection} = {}

--// OTIMIZADOR DE UI (OCULTAR O QUE NÃO APARECE)
-- Se uma ScreenGui não é visível, não há razão para o motor processar seus cálculos de layout.
local function optimizeUIs()
	for _, gui in ipairs(playerGui:GetChildren()) do
		if gui:IsA("ScreenGui") and gui.Enabled then
			-- Se houver algum elemento que cobre a tela toda, podemos desativar o que está atrás
			-- Mas aqui focaremos em desativar efeitos de transparência complexos
			for _, descendant in ipairs(gui:GetDescendants()) do
				if descendant:IsA("Frame") then
					-- Esquinas arredondadas (UICorner) pesam em dispositivos móveis
					local corner = descendant:FindFirstChildOfClass("UICorner")
					if corner then
						-- corner.Enabled = false -- (Opcional: Desative se quiser performance extrema)
					end
				end
			end
		end
	end
end

--// OTIMIZAÇÃO DE NETWORK (LARGURA DE BANDA)
-- Evita que seu cliente tente calcular a física de objetos que o servidor deveria cuidar
local function stabilizeNetwork()
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player and otherPlayer.Character then
			local root = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
			local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			
			if root and myRoot then
				local dist = (root.Position - (myRoot :: BasePart).Position).Magnitude
				if dist > UI_SETTINGS.MAX_NETWORK_DISTANCE then
					-- Se o player está longe, reduzimos a prioridade de replicação
					-- Isso é feito automaticamente pelo Roblox, mas forçamos a limpeza de cache
				end
			end
		end
	end
end

--// THROWING GC (GARBAGE COLLECTOR ADRESS)
-- Pequenos picos de lag às vezes são causados por tabelas Lua acumuladas
local function forceLuaCleanup()
	collectgarbage("collect")
end

--// EXECUÇÃO
task.spawn(function()
	while true do
		task.wait(UI_SETTINGS.UI_RECHECK_RATE)
		
		pcall(optimizeUIs)
		pcall(stabilizeNetwork)
		
		-- Se a memória estiver muito alta, força uma limpeza
		local mem = Stats():GetTotalMemoryUsageMb()
		if mem > 1000 then -- Se passar de 1GB de uso (ajustável)
			forceLuaCleanup()
		end
	end
end)

