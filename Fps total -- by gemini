--!strict

--// SERVICES
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

--// SETTINGS
local SETTINGS = {
    FrameBudget = 0.005,
    ReoptimizeInterval = 20,
    FPS_Thresholds = {
        LOW = 25,
        MEDIUM = 45
    }
}

type Mode = "LOW" | "MEDIUM" | "HIGH"
local currentMode: Mode = "HIGH"
local fps = 60

--// STATE
local processed = {} :: {[Instance]: boolean}

--// FPS MONITOR
task.spawn(function()
    local last = tick()
    local frames = 0

    RunService.Heartbeat:Connect(function()
        frames += 1

        if tick() - last >= 1 then
            fps = frames
            frames = 0
            last = tick()

            if fps <= SETTINGS.FPS_Thresholds.LOW then
                currentMode = "LOW"
            elseif fps <= SETTINGS.FPS_Thresholds.MEDIUM then
                currentMode = "MEDIUM"
            else
                currentMode = "HIGH"
            end
        end
    end)
end)

--// PROTECTION
local function isProtected(obj: Instance): boolean
    if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
        return true
    end

    local player = Players.LocalPlayer
    if player then
        if player.Character and obj:IsDescendantOf(player.Character) then
            return true
        end

        local gui = player:FindFirstChildOfClass("PlayerGui")
        if gui and obj:IsDescendantOf(gui) then
            return true
        end
    end

    return false
end

--// OPTIMIZE INSTANCE
local function optimizeInstance(obj: Instance)
    if processed[obj] or isProtected(obj) then return end
    processed[obj] = true

    if obj:IsA("BasePart") then
        obj.CastShadow = false
        obj.Reflectance = 0

        if currentMode ~= "HIGH" then
            obj.Material = Enum.Material.SmoothPlastic
        end

        if currentMode == "LOW" then
            obj.CanTouch = false
            obj.CanQuery = false
        end

    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        if currentMode == "LOW" then
            obj.Transparency = 1
        end

    elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
        if currentMode ~= "HIGH" then
            obj.Enabled = false
        end

    elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
        if currentMode ~= "HIGH" then
            obj.Enabled = false
        end
    end
end

--// LIGHTING OPTIMIZATION
local function optimizeLighting()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 1

    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") then
            v.Enabled = false
        end
    end
end

--// BATCH PROCESSOR
local function processBatch(list: {Instance})
    local start = os.clock()

    for i, obj in ipairs(list) do
        optimizeInstance(obj)

        if i % 100 == 0 and (os.clock() - start) > SETTINGS.FrameBudget then
            task.wait()
            start = os.clock()
        end
    end
end

--// INITIAL SCAN (RUN ONCE)
local function initialOptimize()
    task.spawn(function()
        processBatch(Workspace:GetDescendants())
    end)
end

--// AUTO OPTIMIZE (LIGHTWEIGHT)
local function autoOptimize()
    task.spawn(function()
        while true do
            task.wait(SETTINGS.ReoptimizeInterval)

            -- só reprocessa objetos novos
            for obj, _ in pairs(processed) do
                if not obj.Parent then
                    processed[obj] = nil
                end
            end
        end
    end)
end

--// NEW OBJECT HANDLER
Workspace.DescendantAdded:Connect(function(obj)
    task.defer(optimizeInstance, obj)
end)

--// LOW LEVEL GRAPHICS
local function applyLowGraphics()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 1
    end
end

--// START
local function start()
    optimizeLighting()
    applyLowGraphics()
    initialOptimize()
    autoOptimize()

    print("✅ FPS Optimizer PRO carregado")
end

start()
